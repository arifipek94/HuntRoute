{
  "name": "globe-fare-frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "npm run validate:quick && next dev",
    "dev:turbo": "next dev --turbo",
    "build": "npm run validate:full && next build",
    "build:analyze": "ANALYZE=true npm run build",
    "start": "next start",
    "lint": "next lint --fix",
    "lint:check": "next lint",
    "type-check": "tsc --noEmit --incremental false",
    "validate": "npm run type-check && npm run lint && npm run build",
    "pre-commit": "npm run type-check && npm run lint",
    "validate:quick": "node scripts/smart-validation.js",
    "validate:full": "npm run validate:quick && npm run type-check && npm run lint",
    "lint:css": "stylelint '**/*.css' --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,md}\"",
    "check-deps": "npm outdated || true",
    "smart:dev": "npm run validate:quick && npm run dev",
    "smart:fix": "npm run format && npm run lint && npm run type-check",
    "smart:validate": "npm run smart:fix && npm run build",
    "smart:clean": "rm -rf .next out dist node_modules/.cache",
    "update-deps": "npm update",
    "clean": "rm -rf .next && rm -rf node_modules/.cache",
    "clean:all": "npm run clean && rm -rf node_modules && npm install",
    "test": "echo \"No tests yet\" && exit 0",
    "test:watch": "echo \"No tests yet\" && exit 0",
    "storybook": "echo \"Storybook not configured\" && exit 0",
    "prepare": "husky",
    "version": "git describe --tags --always",
    "git:status": "git status",
    "git:push": "git add . && git commit -m \"Update: $(date)\" && git push",
    "git:tag": "git tag -a v$(npm run version --silent) -m \"Release v$(npm run version --silent)\"",
    "deploy:check": "npm run validate:full && npm run git:status"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.4",
    "@heroicons/react": "^2.2.0",
    "@radix-ui/react-slot": "^1.0.0",
    "@react-three/drei": "^9.122.0",
    "@react-three/fiber": "^8.18.0",
    "@tanstack/react-query": "^5.0.0",
    "@types/react-datepicker": "^6.2.0",
    "clsx": "^2.0.0",
    "critters": "^0.0.23",
    "framer-motion": "^12.13.0",
    "lucide-react": "^0.511.0",
    "next": "15.3.2",
    "normalize.css": "^8.0.1",
    "react": "^18.0.0",
    "react-datepicker": "^8.4.0",
    "react-dom": "^18.0.0",
    "three": "^0.159.0"
  },
  "devDependencies": {
    "@next/eslint-plugin-next": "^15.3.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/postcss": "^4.1.7",
    "@tailwindcss/typography": "^0.5.16",
    "@tanstack/react-query-devtools": "^5.76.2",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/three": "^0.176.0",
    "autoprefixer": "^10.4.21",
    "cross-env": "^7.0.3",
    "cssnano": "^7.0.7",
    "eslint": "^9.27.0",
    "eslint-config-next": "^15.3.2",
    "eslint-config-prettier": "^10.1.5",
    "eslint-plugin-prettier": "^5.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.0",
    "postcss": "^8",
    "prettier": "^3.5.3",
    "prettier-plugin-tailwindcss": "^0.6.11",
    "stylelint": "^16.19.1",
    "stylelint-config-standard": "^36.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "husky": {
    "hooks": {
      "pre-commit": "npm run pre-commit"
    }
  }
}
