# Smart Development Environment Variables
# Copy this to .env.local and customize as needed

# Development Configuration
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001

# Smart Feature Flags
NEXT_PUBLIC_ENABLE_DEV_TOOLS=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true
NEXT_PUBLIC_ENABLE_REACT_QUERY_DEVTOOLS=true
NEXT_PUBLIC_ENABLE_HOT_RELOAD=true
NEXT_PUBLIC_DEBUG_MODE=true

# Performance & Caching
NEXT_PUBLIC_CACHE_STRATEGY=smart
NEXT_PUBLIC_REVALIDATE_TIME=300
NEXT_PUBLIC_BUNDLE_ANALYZE=false

# Logging & Debugging
NEXT_PUBLIC_LOG_LEVEL=debug
NEXT_PUBLIC_ERROR_REPORTING=console

# Smart Build Options
ANALYZE=false
TURBO=true

# Analytics (leave empty for development)
NEXT_PUBLIC_ANALYTICS_ID=

# API Keys (add your actual keys here)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
# NEXT_PUBLIC_FLIGHT_API_KEY=
